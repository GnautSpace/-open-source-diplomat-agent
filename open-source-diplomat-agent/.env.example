# Environment variables for open-source-diplomat-agent
# Copy to .env and fill in your values. Never commit the filled-in file.

# ── Gemini / Google GenAI ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Set to TRUE only if you are using Gemini Enterprise / Vertex AI
GOOGLE_GENAI_USE_ENTERPRISE=FALSE

# Required when GOOGLE_GENAI_USE_ENTERPRISE=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ── ADK Runner ────────────────────────────────────────────────────────────
# Root agent module for `adk run` / `adk web`
ADK_AGENT_MODULE=app
